{
  "dbus_filters":[
    {
      "name":"SystemD Services",
      "bus":"system",
      "match":"sender='org.freedesktop.systemd1'",
      "types":[
        "method_call",
        "method_return",
        "signal"
      ],
      "log":true,
      "forward":true,
      "enabled":true
    },
    {
      "name":"NetworkManager",
      "bus":"system",
      "match":"sender='org.freedesktop.NetworkManager'",
      "types":[
        "signal",
        "method_return"
      ],
      "log":true,
      "forward":true,
      "enabled":true
    },
    {
      "name":"All D-Bus Traffic",
      "bus":"both",
      "match":"",
      "types":[
        "method_call",
        "method_return",
        "signal",
        "error"
      ],
      "log":false,
      "forward":false,
      "enabled":false
    },
    {
      "name":"NetMon",
      "bus":"system",
      "match":"\"sender='org.freedesktop.NetworkManager'\"",
      "types":[
        "method_return"
      ],
      "log":true,
      "forward":true,
      "enabled":true
    }
  ],
  "global_settings":{
    "default_log":true,
    "default_forward":false,
    "log_file":"logs/dbus_filtered.log",
    "max_message_size":4096
  }
}